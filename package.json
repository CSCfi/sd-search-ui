{
  "name": "sd-search-ui",
  "version": "0.1.0",
  "description": "CSC Discovery Search UI",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "prepare": "simple-git-hooks",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:ci": "run-s lint:oxlint:ci lint:eslint:ci",
    "lint:oxlint:ci": "oxlint .",
    "lint:eslint:ci": "eslint .",
    "format": "prettier --write --experimental-cli src/",
    "format:ci": "prettier --check src/"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{vue,ts,scss,css,json}": "prettier --write --experimental-cli"
  },
  "dependencies": {
    "@cscfi/csc-ui": "^3.0.19",
    "@lucide/vue": "^1.17.0",
    "@tanstack/vue-query": "^5.101.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.10.0",
    "modern-normalize": "^3.0.1",
    "pinia": "^3.0.4",
    "vanilla-cookieconsent": "3.1.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "sass": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^24.18.0 || >=26.0.0"
  }
}
